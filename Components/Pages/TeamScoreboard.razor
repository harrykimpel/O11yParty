<section class="wth-scoreboard">
    <details class="wth-collapse" open="@(!StartCollapsed)">
        <summary>
            <h2>Teams (@Teams.Count)</h2>
        </summary>
        <div class="wth-team-grid">
            @foreach (var team in Teams.OrderByDescending(t => t.Score).ThenBy(t => t.Name))
            {
                <div class="wth-team-card">
                    <span class="team-name">@team.Name</span>
                    <span class="team-score">@team.Score</span>
                </div>
            }
        </div>
    </details>
</section>

@code {
    [Parameter] public IReadOnlyList<Team> Teams { get; set; } = Array.Empty<Team>();

    /// <summary>When true, the scoreboard renders collapsed by default (e.g. on the winner board).</summary>
    [Parameter] public bool StartCollapsed { get; set; }
}
