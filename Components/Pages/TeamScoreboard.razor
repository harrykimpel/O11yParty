<section class="wth-scoreboard">
    <details class="wth-collapse" open="@(!StartCollapsed)">
        <summary>
            <h2>Teams (@Teams.Count)</h2>
        </summary>
        <div class="wth-team-grid">
            @foreach (var team in Teams.OrderByDescending(t => t.Score).ThenBy(t => t.Name))
            {
                var scoreTeam = team;
                <div class="wth-team-card" @key="scoreTeam">
                    <span class="team-name" title="@team.Name">@team.Name</span>
                    <input class="team-score team-score-input" type="number" inputmode="numeric"
                           aria-label="@($"Score for {team.Name} — edit to set manually")"
                           value="@team.Score" @onchange="e => SetScore(scoreTeam, e.Value?.ToString())" />
                </div>
            }
        </div>
        <div class="wth-add-team-row">
            <input class="wth-input" placeholder="Add a team/attendee…"
                   @bind="_newTeamName" @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />
            <button class="wth-button ghost" type="button" @onclick="SubmitNewTeam"
                    disabled="@string.IsNullOrWhiteSpace(_newTeamName)">Add</button>
        </div>
    </details>
</section>

@code {
    [Parameter] public IReadOnlyList<Team> Teams { get; set; } = Array.Empty<Team>();

    /// <summary>When true, the scoreboard renders collapsed by default (e.g. on the winner board).</summary>
    [Parameter] public bool StartCollapsed { get; set; }

    /// <summary>Raised when the host edits a team's score directly to an absolute value.</summary>
    [Parameter] public EventCallback<(Team Team, int Score)> OnScoreSet { get; set; }

    /// <summary>Raised when the host adds a team/attendee from the scoreboard, mid-game.</summary>
    [Parameter] public EventCallback<string> OnTeamAdded { get; set; }

    private string _newTeamName = string.Empty;

    private async Task SetScore(Team team, string? raw)
    {
        // Absolute set: the host types the team's new total. Ignore non-numeric input
        // (the field re-renders back to the real score on the next render).
        if (int.TryParse(raw, out var newScore) && newScore != team.Score)
        {
            await OnScoreSet.InvokeAsync((team, newScore));
        }
    }

    private async Task SubmitNewTeam()
    {
        if (string.IsNullOrWhiteSpace(_newTeamName)) return;
        await OnTeamAdded.InvokeAsync(_newTeamName);
        _newTeamName = string.Empty;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitNewTeam();
    }
}
