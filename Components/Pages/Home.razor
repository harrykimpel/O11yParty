@page "/"
@rendermode InteractiveServer
@inject O11yPartyDataService DataService
@inject NewRelicBuzzService BuzzService
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject IWebHostEnvironment Environment
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>WTH O11yParty</PageTitle>

<section class="wth-app">
    @if (_activeChaos.Count > 0)
    {
        <div class="wth-chaos-banner" role="alert">
            <strong>⚠ CHAOS MODE ACTIVE:</strong>
            @string.Join(" · ", _activeChaos.Select(m => m.ToUpperInvariant()))
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_chaosErrorMessage))
    {
        <div class="wth-chaos-error" role="status" aria-live="polite">
            @_chaosErrorMessage
        </div>
    }

    @if (_showBuzzHighlight && !string.IsNullOrWhiteSpace(_buzzHighlightName))
    {
        <div class="wth-buzz-highlight" role="status" aria-live="assertive" aria-atomic="true">
            <div class="wth-buzz-highlight-card">
                <span class="buzz-kicker">Buzz In</span>
                <strong class="buzz-name">@_buzzHighlightName</strong>
            </div>
        </div>
    }

    <GameHeader Phase="_phase"
                IsBoardValid="IsBoardValid"
                NumberOfQuestions="_numberOfQuestions"
                OnResetGame="ResetGame"
                OnEndGame="EndGame" />

    <TeamScoreboard Teams="_teams" />

    @if (!_isLoaded)
    {
        <section class="wth-panel">
            <h2>Loading board...</h2>
        </section>
    }
    else if (_phase == GamePhase.Setup)
    {
        <GameSetupPanel Teams="_teams"
                        EnableDoubleDown="_enableDoubleDown"
                        EnableDoubleDownChanged="v => _enableDoubleDown = v"
                        EnableTimer="_enableTimer"
                        EnableTimerChanged="v => _enableTimer = v"
                        EnableBuzzer="_enableBuzzer"
                        EnableBuzzerChanged="v => _enableBuzzer = v"
                        QuestionSeconds="_questionSeconds"
                        QuestionSecondsChanged="v => _questionSeconds = v"
                        NumberOfQuestions="_numberOfQuestions"
                        SourceCategories="_sourceCategories"
                        SelectedCategoryNames="_selectedCategoryNames"
                        IsBoardValid="IsBoardValid"
                        OnTeamNameChanged="args => UpdateTeamName(args.Index, args.Value)"
                        OnTeamRemoved="RemoveTeam"
                        OnTeamAdded="AddTeam"
                        OnNumberOfQuestionsChanged="HandleNumberOfQuestionsChanged"
                        OnCategoryToggled="args => ToggleCategory(args.Name, args.Selected)"
                        OnStartGame="StartGame" />
    }
    else if (_phase == GamePhase.Board)
    {
        <GameBoard Categories="_categories"
                   NumberOfQuestions="_numberOfQuestions"
                   OnQuestionSelected="SelectQuestion" />
    }
    else if (_phase is GamePhase.Question or GamePhase.Answer)
    {
        <QuestionPanel Phase="_phase"
                       CurrentQuestion="_currentQuestion"
                       Teams="_teams"
                       EnableTimer="_enableTimer"
                       TimeRemaining="_timeRemaining"
                       EnableBuzzer="_enableBuzzer"
                       BuzzerConfigured="BuzzService.IsConfigured"
                       BuzzerLocked="_buzzerLocked"
                       BuzzedTeam="_buzzedTeam"
                       RemoteBuzzedName="_remoteBuzzedName"
                       MaxWager="_maxWager"
                       OnBuzzIn="BuzzIn"
                       OnBuzzReset="ResetBuzz"
                       OnScoreAdjusted="e => AdjustScore(e.Team, e.Points)"
                       OnRevealAnswer="RevealAnswer"
                       OnReturnToBoard="ReturnToBoard"
                       OnCompleteQuestion="HandleCompleteQuestion" />
    }
    else if (_phase == GamePhase.Winner)
    {
        <WinnerLeaderboard Teams="_teams" OnPlayAgain="ResetGame" />
    }
</section>

@code {
    private bool IsBoardValid
    {
        get
        {
            var requiredLevels = Enumerable.Range(1, _numberOfQuestions).Select(i => i * 100).ToList();
            return _selectedCategoryNames.Count > 0 && _categories.All(category =>
                requiredLevels.All(level =>
                    category.Questions.Any(q => q.Value == level)
                )
            );
        }
    }

    private GamePhase _phase = GamePhase.Setup;
    private readonly List<Team> _teams = new();
    private readonly List<O11yPartyCategory> _sourceCategories = new();
    private readonly List<O11yPartyCategory> _categories = new();
    private readonly HashSet<string> _selectedCategoryNames = new();
    private int _numberOfCategories = 5;
    private int _numberOfQuestions = 5;
    private O11yPartyQuestion? _currentQuestion;
    private bool _isLoaded;
    private bool _enableDoubleDown = true;
    private bool _enableTimer = true;
    private bool _enableBuzzer = true;
    private int _questionSeconds = 30;
    private int _timeRemaining;
    private int _maxWager;
    private bool _buzzerLocked;
    private Team? _buzzedTeam;
    private string? _remoteBuzzedName;
    private bool _scoreApplied;
    private System.Timers.Timer? _timer;
    private CancellationTokenSource? _buzzPollingCancellation;
    private long _questionStartedUnixMs;
    private long _lastHandledBuzzUnixMs;
    private bool _showBuzzHighlight;
    private string? _buzzHighlightName;
    private int _buzzHighlightVersion;

    // Chaos / synthetic failure modes
    [Parameter]
    [SupplyParameterFromQuery(Name = "chaos")]
    public string? ChaosParam { get; set; }
    private HashSet<string> _activeChaos = new(StringComparer.OrdinalIgnoreCase);
    private List<byte[]> _leakedMemory = new();
    private CancellationTokenSource? _chaosCancellation;
    private string? _chaosErrorMessage;
    private int _chaosErrorVersion;

    protected override async Task OnInitializedAsync()
    {
        LoadChaosModes();

        if (_activeChaos.Contains("slowload"))
        {
            Console.WriteLine("[CHAOS] slowload: injecting 4-second startup delay");
            await Task.Delay(4000);
        }

        _numberOfCategories = Configuration.GetValue<int>("Board:NumberOfCategories", 5);
        _numberOfQuestions = Configuration.GetValue<int>("Board:NumberOfQuestions", 5);

        var teamNames = await DataService.GetTeamsAsync();
        _teams.Clear();
        foreach (var name in teamNames)
        {
            _teams.Add(new Team(name));
        }

        if (_teams.Count == 0)
        {
            _teams.Add(new Team("Team Azure"));
            _teams.Add(new Team("Team DevRel"));
        }

        await LoadSourceCategoriesAsync();

        _selectedCategoryNames.Clear();
        foreach (var cat in _sourceCategories.Take(_numberOfCategories))
        {
            _selectedCategoryNames.Add(cat.Name);
        }

        RebuildBoardWithRandomQuestions();

        if (_activeChaos.Contains("memleak"))
        {
            _chaosCancellation = new CancellationTokenSource();
            _ = RunMemoryLeakAsync(_chaosCancellation.Token);
        }

        _isLoaded = true;
    }

    protected override void OnParametersSet()
    {
        var hadMemLeakTask = _chaosCancellation is not null;
        LoadChaosModes();

        if (!_isLoaded)
        {
            return;
        }

        if (_activeChaos.Contains("memleak") && !hadMemLeakTask)
        {
            _chaosCancellation = new CancellationTokenSource();
            _ = RunMemoryLeakAsync(_chaosCancellation.Token);
            return;
        }

        if (!_activeChaos.Contains("memleak") && hadMemLeakTask)
        {
            _chaosCancellation?.Cancel();
            _chaosCancellation?.Dispose();
            _chaosCancellation = null;
        }
    }

    private void LoadChaosModes()
    {
        _activeChaos.Clear();

        var rawChaos = ChaosParam;
        if (string.IsNullOrWhiteSpace(rawChaos))
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            query.TryGetValue("chaos", out var chaosValues);
            rawChaos = chaosValues.FirstOrDefault();
        }

        if (string.IsNullOrWhiteSpace(rawChaos))
        {
            return;
        }

        foreach (var mode in rawChaos.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            _activeChaos.Add(mode);
        }
    }

    [NewRelic.Api.Agent.Transaction]
    private async Task RunMemoryLeakAsync(CancellationToken cancellationToken)
    {
        Console.WriteLine("[CHAOS] memleak: starting memory leak task");
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                _leakedMemory.Add(new byte[1024 * 1024]);
                Console.WriteLine("[CHAOS] memleak: total leaked = {0} MB", _leakedMemory.Count);
            }
        }
        catch (OperationCanceledException) { }
    }

    [NewRelic.Api.Agent.Transaction]
    private async Task LoadSourceCategoriesAsync()
    {
        var boardPath = Path.Combine(Environment.WebRootPath, "data", "o11yparty-board.json");
        if (!File.Exists(boardPath))
        {
            throw new InvalidOperationException($"Board JSON file was not found at '{boardPath}'.");
        }

        var boardJson = await File.ReadAllTextAsync(boardPath);
        if (string.IsNullOrWhiteSpace(boardJson))
        {
            throw new InvalidOperationException($"Board JSON file was empty at '{boardPath}'.");
        }

        if (boardJson.AsSpan().TrimStart().StartsWith("<", StringComparison.Ordinal))
        {
            throw new InvalidOperationException(
                $"Expected JSON from '{boardPath}', but received HTML.");
        }

        using var doc = System.Text.Json.JsonDocument.Parse(boardJson);
        var root = doc.RootElement;
        var categoriesElem = root.GetProperty("categories");

        _sourceCategories.Clear();
        foreach (var catElem in categoriesElem.EnumerateArray())
        {
            var catName = catElem.GetProperty("name").GetString() ?? "";
            var questions = new List<O11yPartyQuestion>();
            if (catElem.TryGetProperty("questionLevels", out var levelsElem))
            {
                foreach (var levelElem in levelsElem.EnumerateArray())
                {
                    var levelValue = levelElem.TryGetProperty("difficulty", out var diffElem) ? diffElem.GetInt32() :
                        (levelElem.TryGetProperty("level", out var lvlElem) ? lvlElem.GetInt32() * 100 : 0);
                    if (levelElem.TryGetProperty("questions", out var qsElem))
                    {
                        foreach (var qElem in qsElem.EnumerateArray())
                        {
                            var prompt = qElem.TryGetProperty("prompt", out var pElem) ? pElem.GetString() ?? "" : "";
                            var answer = qElem.TryGetProperty("answer", out var aElem) ? aElem.GetString() ?? "" : "";
                            questions.Add(new O11yPartyQuestion
                            {
                                Value = levelValue,
                                Prompt = prompt,
                                Answer = answer,
                                CategoryName = catName
                            });
                        }
                    }
                }
            }
            else if (catElem.TryGetProperty("questions", out var flatQsElem))
            {
                foreach (var qElem in flatQsElem.EnumerateArray())
                {
                    var value = qElem.TryGetProperty("value", out var vElem) ? vElem.GetInt32() : 0;
                    var prompt = qElem.TryGetProperty("prompt", out var pElem) ? pElem.GetString() ?? "" : "";
                    var answer = qElem.TryGetProperty("answer", out var aElem) ? aElem.GetString() ?? "" : "";
                    questions.Add(new O11yPartyQuestion
                    {
                        Value = value,
                        Prompt = prompt,
                        Answer = answer,
                        CategoryName = catName
                    });
                }
            }

            _sourceCategories.Add(new O11yPartyCategory
            {
                Name = catName,
                Questions = questions
            });
        }
    }

    [NewRelic.Api.Agent.Transaction]
    private void RebuildBoardWithRandomQuestions()
    {
        var requiredLevels = Enumerable.Range(1, _numberOfQuestions).Select(i => i * 100).ToList();
        _categories.Clear();
        foreach (var sourceCategory in _sourceCategories.Where(c => _selectedCategoryNames.Contains(c.Name)))
        {
            var catName = sourceCategory.Name;
            var questions = sourceCategory.Questions;

            var questionsForLevels = requiredLevels
                .Select(level =>
                {
                    var matchingQuestions = questions.Where(q => q.Value == level).ToList();
                    if (matchingQuestions.Count == 0) return null;
                    var selected = matchingQuestions[Random.Shared.Next(matchingQuestions.Count)];
                    return new O11yPartyQuestion
                    {
                        Value = selected.Value,
                        Prompt = selected.Prompt,
                        Answer = selected.Answer,
                        CategoryName = catName
                    };
                })
                .OfType<O11yPartyQuestion>()
                .ToList();

            _categories.Add(new O11yPartyCategory
            {
                Name = catName,
                Questions = questionsForLevels!
            });
        }

        _maxWager = _categories.SelectMany(c => c.Questions).DefaultIfEmpty(new O11yPartyQuestion { Value = 500 }).Max(q => q.Value);
    }

    [NewRelic.Api.Agent.Transaction]
    private void ToggleCategory(string name, bool selected)
    {
        if (selected)
            _selectedCategoryNames.Add(name);
        else
            _selectedCategoryNames.Remove(name);

        _numberOfCategories = _selectedCategoryNames.Count;
        RebuildBoardWithRandomQuestions();
    }

    private void HandleNumberOfQuestionsChanged(int val)
    {
        _numberOfQuestions = val;
        RebuildBoardWithRandomQuestions();
    }

    [NewRelic.Api.Agent.Transaction]
    private void StartGame()
    {
        RebuildBoardWithRandomQuestions();

        if (_teams.All(t => string.IsNullOrWhiteSpace(t.Name))) return;
        if (!IsBoardValid) return;

        foreach (var team in _teams)
        {
            team.Name = team.Name.Trim();
            team.Score = 0;
        }

        foreach (var question in _categories.SelectMany(c => c.Questions))
        {
            question.IsAnswered = false;
            question.IsDoubleDown = false;
        }

        if (_enableDoubleDown) AssignDoubleDowns();

        _phase = GamePhase.Board;
        _currentQuestion = null;
        ResetBuzzState();
    }

    [NewRelic.Api.Agent.Transaction]
    private void ResetGame()
    {
        StopBuzzPolling();
        StopTimer();
        _phase = GamePhase.Setup;
        _currentQuestion = null;
        ResetBuzzState();
    }

    [NewRelic.Api.Agent.Transaction]
    private void EndGame()
    {
        StopBuzzPolling();
        StopTimer();
        _phase = GamePhase.Winner;
    }

    private void AddTeam()
    {
        _teams.Add(new Team($"Team {_teams.Count + 1}"));
    }

    private void RemoveTeam(int index)
    {
        if (_teams.Count <= 1) return;
        _teams.RemoveAt(index);
    }

    private void UpdateTeamName(int index, string? value)
    {
        _teams[index].Name = value ?? string.Empty;
    }

    [NewRelic.Api.Agent.Transaction]
    private async Task SelectQuestion(O11yPartyQuestion question)
    {
        if (question.IsAnswered) return;

        if (_activeChaos.Contains("errors") && Random.Shared.NextDouble() < 0.4)
        {
            Console.WriteLine("[CHAOS] errors: synthetic question load failure");
            ShowChaosError("[CHAOS] Failed to load this question. Try selecting it again.");
            return;
        }

        if (_activeChaos.Contains("latency"))
        {
            var delayMs = Random.Shared.Next(1500, 4000);
            Console.WriteLine("[CHAOS] latency: injecting {0}ms delay", delayMs);
            await Task.Delay(delayMs);
        }

        _currentQuestion = question;
        _phase = GamePhase.Question;
        _maxWager = Math.Max(
            _categories.SelectMany(c => c.Questions).Max(q => q.Value),
            _teams.Max(t => t.Score));
        _scoreApplied = false;
        ResetBuzzState();
        StartTimer();
        StartBuzzPolling();
    }

    private void ShowChaosError(string message)
    {
        _chaosErrorMessage = message;
        var currentVersion = ++_chaosErrorVersion;
        _ = HideChaosErrorAfterDelayAsync(currentVersion);
    }

    private async Task HideChaosErrorAfterDelayAsync(int expectedVersion)
    {
        try { await Task.Delay(TimeSpan.FromSeconds(3)); }
        catch (TaskCanceledException) { return; }

        if (expectedVersion != _chaosErrorVersion) return;

        await InvokeAsync(() =>
        {
            if (expectedVersion != _chaosErrorVersion) return;
            _chaosErrorMessage = null;
            StateHasChanged();
        });
    }

    private void RevealAnswer()
    {
        StopBuzzPolling();
        StopTimer();
        _phase = GamePhase.Answer;
    }

    private void ReturnToBoard()
    {
        StopBuzzPolling();
        StopTimer();
        _phase = GamePhase.Board;
        _currentQuestion = null;
        ResetBuzzState();
    }

    [NewRelic.Api.Agent.Transaction]
    private void HandleCompleteQuestion(int questionPoints)
    {
        if (_currentQuestion is null) return;

        if (!_scoreApplied && _buzzedTeam is not null)
        {
            AdjustScore(_buzzedTeam, questionPoints);
        }

        StopBuzzPolling();
        StopTimer();
        _currentQuestion.IsAnswered = true;
        _currentQuestion = null;
        ResetBuzzState();
        _phase = _categories.SelectMany(c => c.Questions).All(q => q.IsAnswered)
            ? GamePhase.Winner
            : GamePhase.Board;
    }

    [NewRelic.Api.Agent.Transaction]
    private async void AdjustScore(Team team, int delta)
    {
        team.Score += delta;
        _scoreApplied = true;
        await JS.InvokeAsync<string>("RecordTeamScore", team.Name, team.Score);
    }

    private void BuzzIn(Team team)
    {
        if (_buzzerLocked) return;
        _buzzedTeam = team;
        _buzzerLocked = true;
        StopTimer();
        ShowBuzzHighlight(team.Name);
    }

    private void ResetBuzzState()
    {
        _buzzerLocked = false;
        _buzzedTeam = null;
        _remoteBuzzedName = null;
        _scoreApplied = false;
        ClearBuzzHighlight();
    }

    private void ShowBuzzHighlight(string teamName)
    {
        if (string.IsNullOrWhiteSpace(teamName)) return;
        _buzzHighlightName = teamName;
        _showBuzzHighlight = true;
        var currentVersion = ++_buzzHighlightVersion;
        _ = HideBuzzHighlightAfterDelayAsync(currentVersion);
    }

    private async Task HideBuzzHighlightAfterDelayAsync(int expectedVersion)
    {
        try { await Task.Delay(TimeSpan.FromSeconds(5)); }
        catch (TaskCanceledException) { return; }

        if (expectedVersion != _buzzHighlightVersion) return;

        await InvokeAsync(() =>
        {
            if (expectedVersion != _buzzHighlightVersion) return;
            _showBuzzHighlight = false;
            StateHasChanged();
        });
    }

    private void ClearBuzzHighlight()
    {
        _buzzHighlightVersion++;
        _showBuzzHighlight = false;
        _buzzHighlightName = null;
    }

    private void ResetBuzz()
    {
        ResetBuzzState();
        _questionStartedUnixMs = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _lastHandledBuzzUnixMs = _questionStartedUnixMs;
        StartTimer();
    }

    private void StartBuzzPolling()
    {
        StopBuzzPolling();
        if (!_enableBuzzer || !BuzzService.IsConfigured) return;
        _questionStartedUnixMs = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _lastHandledBuzzUnixMs = _questionStartedUnixMs;
        _buzzPollingCancellation = new CancellationTokenSource();
        _ = PollRemoteBuzzAsync(_buzzPollingCancellation.Token);
    }

    private void StopBuzzPolling()
    {
        if (_buzzPollingCancellation is null) return;
        _buzzPollingCancellation.Cancel();
        _buzzPollingCancellation.Dispose();
        _buzzPollingCancellation = null;
    }

    private async Task PollRemoteBuzzAsync(CancellationToken cancellationToken)
    {
        using var pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await pollTimer.WaitForNextTickAsync(cancellationToken))
            {
                if (_phase != GamePhase.Question || _buzzerLocked) continue;

                var buzz = await BuzzService.GetLatestBuzzAsync(cancellationToken);
                if (buzz is null) continue;

                if (buzz.TimestampUnixMs <= _lastHandledBuzzUnixMs || buzz.TimestampUnixMs < _questionStartedUnixMs)
                    continue;

                _lastHandledBuzzUnixMs = buzz.TimestampUnixMs;
                Console.WriteLine("Handling remote buzz: Name={0}, Timestamp={1}", buzz.Name, buzz.TimestampUnixMs);
                await InvokeAsync(() => HandleRemoteBuzz(buzz.Name));
            }
        }
        catch (OperationCanceledException) { }
    }

    private void HandleRemoteBuzz(string participantName)
    {
        if (_buzzerLocked || string.IsNullOrWhiteSpace(participantName)) return;

        var normalizedName = participantName.Trim();
        var matchingTeam = _teams.FirstOrDefault(team =>
            string.Equals(team.Name, normalizedName, StringComparison.OrdinalIgnoreCase));

        if (matchingTeam is not null)
        {
            _remoteBuzzedName = matchingTeam.Name;
            BuzzIn(matchingTeam);
            StateHasChanged();
            return;
        }

        Console.WriteLine("Ignoring remote buzz from unknown team: {0}", normalizedName);
    }

    private void StartTimer()
    {
        StopTimer();
        if (!_enableTimer || _phase != GamePhase.Question) return;

        _timeRemaining = Math.Max(1, _questionSeconds);
        var timerIntervalMs = _activeChaos.Contains("timerdrift") ? 500 : 1000;
        if (_activeChaos.Contains("timerdrift")) Console.WriteLine("[CHAOS] timerdrift: timer running at 2x speed");
        _timer = new System.Timers.Timer(timerIntervalMs);
        _timer.Elapsed += async (_, _) =>
        {
            if (_phase != GamePhase.Question) return;
            _timeRemaining--;
            if (_timeRemaining <= 0)
            {
                _timeRemaining = 0;
                StopTimer();
                _phase = GamePhase.Answer;
                _buzzerLocked = true;
            }
            await InvokeAsync(StateHasChanged);
        };
        _timer.AutoReset = true;
        _timer.Start();
    }

    private void StopTimer()
    {
        if (_timer is null) return;
        _timer.Stop();
        _timer.Dispose();
        _timer = null;
    }

    private void AssignDoubleDowns()
    {
        var allQuestions = _categories.SelectMany(c => c.Questions).ToList();
        if (allQuestions.Count == 0) return;
        var doubleDownCount = Math.Max(1, _categories.Count / 3);
        foreach (var question in allQuestions.OrderBy(_ => Random.Shared.Next()).Take(doubleDownCount))
        {
            question.IsDoubleDown = true;
        }
    }

    public void Dispose()
    {
        StopBuzzPolling();
        StopTimer();
        _chaosErrorVersion++;
        _chaosCancellation?.Cancel();
        _chaosCancellation?.Dispose();
        _chaosCancellation = null;
    }
}
