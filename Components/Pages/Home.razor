@page "/"
@rendermode InteractiveServer
@inject O11yPartyDataService DataService
@inject NewRelicBuzzService BuzzService
@inject IBuzzNotifier BuzzNotifier
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject IWebHostEnvironment Environment
@inject NavigationManager Navigation
@implements IDisposable
@inject ILogger<Home> Logger

<PageTitle>O11yParty</PageTitle>

<section class="wth-app">
    @if (_activeChaos.Count > 0)
    {
        <div class="wth-chaos-banner" role="alert">
            <strong>⚠ CHAOS MODE ACTIVE:</strong>
            @string.Join(" · ", _activeChaos.Select(m => m.ToUpperInvariant()))
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_chaosErrorMessage))
    {
        <div class="wth-chaos-error" role="status" aria-live="polite">
            @_chaosErrorMessage
        </div>
    }

    @if (_showBuzzHighlight && !string.IsNullOrWhiteSpace(_buzzHighlightName))
    {
        <div class="wth-buzz-highlight" role="status" aria-live="assertive" aria-atomic="true">
            <div class="wth-buzz-highlight-card">
                <span class="buzz-kicker">Buzz In</span>
                <strong class="buzz-name">@_buzzHighlightName</strong>
            </div>
        </div>
    }

    @if (_showScoreToast && !string.IsNullOrWhiteSpace(_lastScoreMessage))
    {
        <div class="wth-score-toast" role="status" aria-live="polite" aria-atomic="true">
            <span class="score-toast-icon">✓</span>
            <span class="score-toast-text">@_lastScoreMessage</span>
        </div>
    }

    <GameHeader Phase="_phase" IsBoardValid="IsBoardValid" NumberOfQuestions="_numberOfQuestions"
                OnResetGame="ResetGame" OnEndGame="EndGame" />

    <TeamScoreboard Teams="_teams" StartCollapsed="true" OnScoreSet="args => SetScore(args.Team, args.Score)" />

    @if (!_isLoaded)
    {
        <section class="wth-panel">
            <h2>Loading board...</h2>
        </section>
    }
    else if (_phase == GamePhase.Setup)
    {
        <GameSetupPanel Teams="_teams" EnableDoubleDown="_enableDoubleDown"
                        EnableDoubleDownChanged="v => _enableDoubleDown = v" EnableTimer="_enableTimer"
                        EnableTimerChanged="v => _enableTimer = v" EnableBuzzer="_enableBuzzer"
                        EnableBuzzerChanged="v => _enableBuzzer = v" QuestionSeconds="_questionSeconds"
                        QuestionSecondsChanged="v => _questionSeconds = v" NumberOfQuestions="_numberOfQuestions"
                        SourceCategories="_sourceCategories" SelectedCategoryNames="_selectedCategoryNames" IsBoardValid="IsBoardValid"
                        OnTeamNameChanged="args => UpdateTeamName(args.Index, args.Value)" OnTeamRemoved="RemoveTeam"
                        OnTeamAdded="AddTeam" OnNumberOfQuestionsChanged="HandleNumberOfQuestionsChanged"
                        OnCategoryToggled="args => ToggleCategory(args.Name, args.Selected)" OnTeamsPasted="ReplaceTeams"
                        OnQuestionsImported="ImportQuestions" ImportMessage="@_importMessage"
                        OnStartGame="StartGame" />
    }
    else if (_phase == GamePhase.Board)
    {
        <GameBoard Categories="_categories" NumberOfQuestions="_numberOfQuestions" OnQuestionSelected="SelectQuestion" />
    }
    else if (_phase is GamePhase.Question or GamePhase.Answer)
    {
        <QuestionPanel Phase="_phase" CurrentQuestion="_currentQuestion" Teams="_teams" EnableTimer="_enableTimer"
                       TimeRemaining="_timeRemaining" EnableBuzzer="_enableBuzzer" BuzzerConfigured="BuzzService.IsConfigured"
                       BuzzerLocked="_buzzerLocked" BuzzedTeam="_buzzedTeam" RemoteBuzzedName="@_remoteBuzzedName" MaxWager="_maxWager"
                       IsScoreCoolingDown="IsScoreCoolingDown"
                       OnBuzzIn="BuzzIn" OnBuzzReset="ResetBuzz" OnScoreAdjusted="e => AdjustScore(e.Team, e.Points)"
                       OnRevealAnswer="RevealAnswer" OnReturnToBoard="ReturnToBoard" OnCompleteQuestion="HandleCompleteQuestion" />
    }
    else if (_phase == GamePhase.Winner)
    {
        <WinnerLeaderboard Teams="_teams" OnPlayAgain="ResetGame" />
    }
</section>

@code {
    private bool IsBoardValid
    {
        get
        {
            var requiredLevels = Enumerable.Range(1, _numberOfQuestions).Select(i => i * 100).ToList();
            return _selectedCategoryNames.Count > 0 && _categories.All(category =>
                requiredLevels.All(level =>
                    category.Questions.Any(q => q.Value == level)
                )
            );
        }
    }

    private GamePhase _phase = GamePhase.Setup;
    private readonly List<Team> _teams = new();
    private readonly List<O11yPartyCategory> _sourceCategories = new();
    private readonly List<O11yPartyCategory> _categories = new();
    private readonly HashSet<string> _selectedCategoryNames = new();
    private int _numberOfCategories = 5;
    private int _numberOfQuestions = 5;
    private O11yPartyQuestion? _currentQuestion;
    private bool _isLoaded;
    private bool _enableDoubleDown = true;
    private bool _enableTimer = true;
    private bool _enableBuzzer = true;
    private int _questionSeconds = 30;
    private int _timeRemaining;
    private int _maxWager;
    private bool _buzzerLocked;
    private Team? _buzzedTeam;
    private string? _remoteBuzzedName;
    private bool _scoreApplied;
    private System.Timers.Timer? _timer;
    private CancellationTokenSource? _buzzPollingCancellation;
    private long _questionStartedUnixMs;
    private long _lastHandledBuzzUnixMs;
    private bool _showBuzzHighlight;
    private string? _buzzHighlightName;
    private int _buzzHighlightVersion;

    // Transport selection: when false (default) use IBuzzNotifier (SignalR push);
    // when true use the legacy NewRelicBuzzService polling path.
    private bool _useLegacyBuzzPolling;

    // Timestamp-authoritative buzz selection (SignalR push path only).
    // SignalR delivers buzzes in arrival order, which network jitter can reorder. To award the
    // team that actually buzzed first, the first buzz opens a short collection window; every buzz
    // that lands within it is gathered, then the lowest server-stamped buzzedAtUtcMs wins.
    // The legacy NR path is unaffected — NRQL earliest() already resolves the winner server-side.
    private const int BuzzWindowMs = 400;
    private readonly List<(Team Team, long Ts)> _buzzCandidates = new();
    private bool _collectingBuzzes;
    private int _buzzRoundId;

    // Chaos / synthetic failure modes
    [Parameter]
    [SupplyParameterFromQuery(Name = "chaos")]
    public string? ChaosParam { get; set; }
    private HashSet<string> _activeChaos = new(StringComparer.OrdinalIgnoreCase);
    private List<byte[]> _leakedMemory = new();
    private CancellationTokenSource? _chaosCancellation;
    private string? _chaosErrorMessage;
    private int _chaosErrorVersion;

    protected override async Task OnInitializedAsync()
    {
        LoadChaosModes();

        if (_activeChaos.Contains("slowload"))
        {
            Logger.LogWarning("[CHAOS] slowload: injecting 4-second startup delay");
            await Task.Delay(4000);
        }

        _numberOfCategories = Configuration.GetValue<int>("Board:NumberOfCategories", 5);
        _numberOfQuestions = Configuration.GetValue<int>("Board:NumberOfQuestions", 5);
        _useLegacyBuzzPolling = Configuration.GetValue<bool>("NewRelic:UseLegacyBuzzPolling", false);

        if (!_useLegacyBuzzPolling)
        {
            BuzzNotifier.BuzzReceived += OnBuzzNotification;
        }

        var teamNames = await DataService.GetTeamsAsync();
        _teams.Clear();
        foreach (var name in teamNames)
        {
            _teams.Add(new Team(name));
        }

        if (_teams.Count == 0)
        {
            _teams.Add(new Team("Team Azure"));
            _teams.Add(new Team("Team DevRel"));
        }

        await LoadSourceCategoriesAsync();

        _selectedCategoryNames.Clear();
        foreach (var cat in _sourceCategories.Take(_numberOfCategories))
        {
            _selectedCategoryNames.Add(cat.Name);
        }

        RebuildBoardWithRandomQuestions();

        if (_activeChaos.Contains("memleak"))
        {
            _chaosCancellation = new CancellationTokenSource();
            _ = RunMemoryLeakAsync(_chaosCancellation.Token);
        }

        _isLoaded = true;
    }

    protected override void OnParametersSet()
    {
        var hadMemLeakTask = _chaosCancellation is not null;
        LoadChaosModes();

        if (!_isLoaded)
        {
            return;
        }

        if (_activeChaos.Contains("memleak") && !hadMemLeakTask)
        {
            _chaosCancellation = new CancellationTokenSource();
            _ = RunMemoryLeakAsync(_chaosCancellation.Token);
            return;
        }

        if (!_activeChaos.Contains("memleak") && hadMemLeakTask)
        {
            _chaosCancellation?.Cancel();
            _chaosCancellation?.Dispose();
            _chaosCancellation = null;
        }
    }

    private void LoadChaosModes()
    {
        _activeChaos.Clear();

        var rawChaos = ChaosParam;
        if (string.IsNullOrWhiteSpace(rawChaos))
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            query.TryGetValue("chaos", out var chaosValues);
            rawChaos = chaosValues.FirstOrDefault();
        }

        if (string.IsNullOrWhiteSpace(rawChaos))
        {
            return;
        }

        foreach (var mode in rawChaos.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            _activeChaos.Add(mode);
        }
    }

    [NewRelic.Api.Agent.Transaction]
    private async Task RunMemoryLeakAsync(CancellationToken cancellationToken)
    {
        Logger.LogWarning("[CHAOS] memleak: starting memory leak task");
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                _leakedMemory.Add(new byte[1024 * 1024]);
                Logger.LogWarning("[CHAOS] memleak: total leaked = {0} MB", _leakedMemory.Count);
            }
        }
        catch (OperationCanceledException) { }
    }

    [NewRelic.Api.Agent.Transaction]
    private async Task LoadSourceCategoriesAsync()
    {
        var webRoot = Environment.WebRootPath ?? Path.Combine(Environment.ContentRootPath, "wwwroot");
        var boardPath = Path.Combine(webRoot, "data", "o11yparty-board.json");
        if (!File.Exists(boardPath))
        {
            throw new InvalidOperationException($"Board JSON file was not found at '{boardPath}'.");
        }

        var boardJson = await File.ReadAllTextAsync(boardPath);
        if (string.IsNullOrWhiteSpace(boardJson))
        {
            throw new InvalidOperationException($"Board JSON file was empty at '{boardPath}'.");
        }

        if (boardJson.AsSpan().TrimStart().StartsWith("<", StringComparison.Ordinal))
        {
            throw new InvalidOperationException(
                $"Expected JSON from '{boardPath}', but received HTML.");
        }

        using var doc = System.Text.Json.JsonDocument.Parse(boardJson);
        var root = doc.RootElement;
        var categoriesElem = root.GetProperty("categories");

        _sourceCategories.Clear();
        foreach (var catElem in categoriesElem.EnumerateArray())
        {
            var catName = catElem.GetProperty("name").GetString() ?? "";
            var questions = new List<O11yPartyQuestion>();
            if (catElem.TryGetProperty("questionLevels", out var levelsElem))
            {
                foreach (var levelElem in levelsElem.EnumerateArray())
                {
                    var levelValue = levelElem.TryGetProperty("difficulty", out var diffElem) ? diffElem.GetInt32() :
                        (levelElem.TryGetProperty("level", out var lvlElem) ? lvlElem.GetInt32() * 100 : 0);
                    if (levelElem.TryGetProperty("questions", out var qsElem))
                    {
                        foreach (var qElem in qsElem.EnumerateArray())
                        {
                            var prompt = qElem.TryGetProperty("prompt", out var pElem) ? pElem.GetString() ?? "" : "";
                            var answer = qElem.TryGetProperty("answer", out var aElem) ? aElem.GetString() ?? "" : "";
                            questions.Add(new O11yPartyQuestion
                            {
                                Value = levelValue,
                                Prompt = prompt,
                                Answer = answer,
                                CategoryName = catName
                            });
                        }
                    }
                }
            }
            else if (catElem.TryGetProperty("questions", out var flatQsElem))
            {
                foreach (var qElem in flatQsElem.EnumerateArray())
                {
                    var value = qElem.TryGetProperty("value", out var vElem) ? vElem.GetInt32() : 0;
                    var prompt = qElem.TryGetProperty("prompt", out var pElem) ? pElem.GetString() ?? "" : "";
                    var answer = qElem.TryGetProperty("answer", out var aElem) ? aElem.GetString() ?? "" : "";
                    questions.Add(new O11yPartyQuestion
                    {
                        Value = value,
                        Prompt = prompt,
                        Answer = answer,
                        CategoryName = catName
                    });
                }
            }

            _sourceCategories.Add(new O11yPartyCategory
            {
                Name = catName,
                Questions = questions
            });
        }
    }

    [NewRelic.Api.Agent.Transaction]
    private void RebuildBoardWithRandomQuestions()
    {
        var requiredLevels = Enumerable.Range(1, _numberOfQuestions).Select(i => i * 100).ToList();
        _categories.Clear();
        foreach (var sourceCategory in _sourceCategories.Where(c => _selectedCategoryNames.Contains(c.Name)))
        {
            var catName = sourceCategory.Name;
            var questions = sourceCategory.Questions;

            var questionsForLevels = requiredLevels
                .Select(level =>
                {
                    var matchingQuestions = questions.Where(q => q.Value == level).ToList();
                    if (matchingQuestions.Count == 0) return null;
                    var selected = matchingQuestions[Random.Shared.Next(matchingQuestions.Count)];
                    return new O11yPartyQuestion
                    {
                        Value = selected.Value,
                        Prompt = selected.Prompt,
                        Answer = selected.Answer,
                        CategoryName = catName
                    };
                })
                .OfType<O11yPartyQuestion>()
                .ToList();

            _categories.Add(new O11yPartyCategory
            {
                Name = catName,
                Questions = questionsForLevels!
            });
        }

        _maxWager = _categories.SelectMany(c => c.Questions).DefaultIfEmpty(new O11yPartyQuestion { Value = 500 }).Max(q =>
q.Value);
    }

    [NewRelic.Api.Agent.Transaction]
    private void ToggleCategory(string name, bool selected)
    {
        if (selected)
            _selectedCategoryNames.Add(name);
        else
            _selectedCategoryNames.Remove(name);

        _numberOfCategories = _selectedCategoryNames.Count;
        RebuildBoardWithRandomQuestions();
    }

    private void HandleNumberOfQuestionsChanged(int val)
    {
        _numberOfQuestions = val;
        RebuildBoardWithRandomQuestions();
    }

    [NewRelic.Api.Agent.Transaction]
    private void StartGame()
    {
        RebuildBoardWithRandomQuestions();

        if (_teams.All(t => string.IsNullOrWhiteSpace(t.Name))) return;
        if (!IsBoardValid) return;

        foreach (var team in _teams)
        {
            team.Name = team.Name.Trim();
            team.Score = 0;
        }

        foreach (var question in _categories.SelectMany(c => c.Questions))
        {
            question.IsAnswered = false;
            question.IsDoubleDown = false;
        }

        if (_enableDoubleDown) AssignDoubleDowns();

        _phase = GamePhase.Board;
        _currentQuestion = null;
        ResetBuzzState();
    }

    [NewRelic.Api.Agent.Transaction]
    private void ResetGame()
    {
        CloseBuzzWindow();
        StopTimer();
        _phase = GamePhase.Setup;
        _currentQuestion = null;
        ResetBuzzState();
    }

    [NewRelic.Api.Agent.Transaction]
    private void EndGame()
    {
        CloseBuzzWindow();
        StopTimer();
        _phase = GamePhase.Winner;
    }

    private void AddTeam()
    {
        _teams.Add(new Team($"Team {_teams.Count + 1}"));
    }

    /// <summary>
    /// Replaces the whole team list from a pasted block (one name per line, or
    /// comma-separated) — overrides whatever was loaded from teams.json at startup.
    /// Trims, drops blanks, de-dupes (case-insensitive), and caps the count.
    /// </summary>
    private void ReplaceTeams(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return;

        var names = raw
            .Split(new[] { '\n', '\r', ',' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(500)
            .ToList();

        if (names.Count == 0) return;

        _teams.Clear();
        foreach (var name in names)
        {
            _teams.Add(new Team(name));
        }
    }

    private string? _importMessage;

    /// <summary>
    /// Extends the board from pasted TSV (cols: Category, Value, Prompt, Answer, [DoubleDown]).
    /// Questions for an existing category name are appended; a new category is created and
    /// auto-selected. Reports a summary + any skipped rows via <see cref="_importMessage"/>.
    /// </summary>
    [NewRelic.Api.Agent.Transaction]
    private void ImportQuestions(string? tsv)
    {
        if (string.IsNullOrWhiteSpace(tsv))
        {
            _importMessage = "Nothing to import.";
            return;
        }

        var lines = tsv.Replace("\r\n", "\n").Replace("\r", "\n").Split('\n');
        var existingBefore = new HashSet<string>(_sourceCategories.Select(c => c.Name), StringComparer.OrdinalIgnoreCase);
        var createdCats = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var touchedCats = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var nonTierValues = new SortedSet<int>();
        int added = 0, skipped = 0;
        var errors = new List<string>();

        for (var i = 0; i < lines.Length; i++)
        {
            var line = lines[i];
            if (string.IsNullOrWhiteSpace(line)) continue;

            var cols = line.Split('\t');
            // Skip an optional header row (first non-empty line whose Value column isn't numeric).
            if (i == 0 && cols.Length >= 2 && !int.TryParse(cols[1].Trim(), out _)) continue;

            if (cols.Length < 4)
            {
                skipped++;
                if (errors.Count < 5) errors.Add($"line {i + 1}: expected 4+ tab-separated columns");
                continue;
            }

            var category = cols[0].Trim();
            var prompt = cols[2].Trim();
            var answer = cols[3].Trim();
            var doubleDown = cols.Length >= 5 && IsTruthy(cols[4]);

            if (category.Length == 0 || prompt.Length == 0 || answer.Length == 0 || !int.TryParse(cols[1].Trim(), out var value) || value <= 0)
            {
                skipped++;
                if (errors.Count < 5) errors.Add($"line {i + 1}: needs Category, positive Value, Prompt, Answer");
                continue;
            }

            if (value % 100 != 0) nonTierValues.Add(value);

            var cat = _sourceCategories.FirstOrDefault(c => string.Equals(c.Name, category, StringComparison.OrdinalIgnoreCase));
            if (cat is null)
            {
                cat = new O11yPartyCategory { Name = category };
                _sourceCategories.Add(cat);
                createdCats.Add(category);
            }

            cat.Questions.Add(new O11yPartyQuestion
            {
                Value = value,
                Prompt = prompt,
                Answer = answer,
                IsDoubleDown = doubleDown,
                CategoryName = cat.Name
            });
            touchedCats.Add(cat.Name);
            added++;
        }

        // Auto-select newly created categories so they're immediately in play.
        foreach (var name in createdCats) _selectedCategoryNames.Add(name);
        _numberOfCategories = _selectedCategoryNames.Count;
        RebuildBoardWithRandomQuestions();

        if (added == 0)
        {
            _importMessage = $"No questions added — skipped {skipped} row(s)." + (errors.Count > 0 ? " " + string.Join("; ", errors) : "");
            return;
        }

        var extended = touchedCats.Count - createdCats.Count;
        var msg = $"Added {added} question(s): {createdCats.Count} new categor{(createdCats.Count == 1 ? "y" : "ies")}, {extended} extended.";
        if (skipped > 0) msg += $" Skipped {skipped} row(s).";
        if (nonTierValues.Count > 0) msg += $" Note: values {string.Join(", ", nonTierValues)} aren't multiples of 100, so they won't appear on the board's point tiers.";
        _importMessage = msg;
    }

    private static bool IsTruthy(string? s)
    {
        s = s?.Trim().ToLowerInvariant();
        return s is "true" or "yes" or "y" or "1" or "x" or "✓" or "dd";
    }

    private void RemoveTeam(int index)
    {
        if (_teams.Count <= 1) return;
        _teams.RemoveAt(index);
    }

    private void UpdateTeamName(int index, string? value)
    {
        _teams[index].Name = value ?? string.Empty;
    }

    [NewRelic.Api.Agent.Transaction]
    private async Task SelectQuestion(O11yPartyQuestion question)
    {
        if (question.IsAnswered) return;

        if (_activeChaos.Contains("errors") && Random.Shared.NextDouble() < 0.4)
        {
            Logger.LogError("[CHAOS] errors: synthetic question load failure");
            ShowChaosError("[CHAOS] Failed to load this question. Try selecting it again.");
            NewRelic.Api.Agent.NewRelic.NoticeError(new Exception("Synthetic question load failure"));
            return;
        }

        if (_activeChaos.Contains("latency"))
        {
            var delayMs = Random.Shared.Next(1500, 4000);
            Logger.LogWarning("[CHAOS] latency: injecting {0}ms delay", delayMs);
            await Task.Delay(delayMs);
        }

        _currentQuestion = question;
        _phase = GamePhase.Question;
        _lastScoreMessage = null; // clear any confirmation from the previous question
        _showScoreToast = false;
        _maxWager = Math.Max(
            _categories.SelectMany(c => c.Questions).Max(q => q.Value),
            _teams.Max(t => t.Score));
        _scoreApplied = false;
        ResetBuzzState();
        StartTimer();
        OpenBuzzWindow();
    }

    private void ShowChaosError(string message)
    {
        _chaosErrorMessage = message;
        var currentVersion = ++_chaosErrorVersion;
        _ = HideChaosErrorAfterDelayAsync(currentVersion);
    }

    private async Task HideChaosErrorAfterDelayAsync(int expectedVersion)
    {
        try { await Task.Delay(TimeSpan.FromSeconds(3)); }
        catch (TaskCanceledException) { return; }

        if (expectedVersion != _chaosErrorVersion) return;

        await InvokeAsync(() =>
        {
            if (expectedVersion != _chaosErrorVersion) return;
            _chaosErrorMessage = null;
            StateHasChanged();
        });
    }

    private void RevealAnswer()
    {
        CloseBuzzWindow();
        StopTimer();
        _phase = GamePhase.Answer;
    }

    private void ReturnToBoard()
    {
        CloseBuzzWindow();
        StopTimer();
        _phase = GamePhase.Board;
        _currentQuestion = null;
        ResetBuzzState();
    }

    [NewRelic.Api.Agent.Transaction]
    private void HandleCompleteQuestion(int questionPoints)
    {
        if (_currentQuestion is null) return;

        if (!_scoreApplied && _buzzedTeam is not null)
        {
            AdjustScore(_buzzedTeam, questionPoints);
        }

        CloseBuzzWindow();
        StopTimer();
        _currentQuestion.IsAnswered = true;
        _currentQuestion = null;
        ResetBuzzState();
        _phase = _categories.SelectMany(c => c.Questions).All(q => q.IsAnswered)
            ? GamePhase.Winner
            : GamePhase.Board;
    }

    // After a score button is clicked it's briefly disabled and a confirmation is
    // shown, so the host gets clear feedback the click registered and can't
    // accidentally double-apply points. State lives here (not in QuestionPanel) so the
    // background re-enable render reliably flushes to the client and cascades down.
    private const int ScoreButtonCooldownSeconds = 5;
    private const int ScoreToastSeconds = 3;
    private readonly HashSet<string> _scoreCooldownKeys = new();
    private string? _lastScoreMessage;
    private bool _showScoreToast;
    private int _scoreToastVersion;

    private static string ScoreCooldownKey(Team team, int points) => $"{team.Name}|{points}";

    private bool IsScoreCoolingDown(Team team, int points) => _scoreCooldownKeys.Contains(ScoreCooldownKey(team, points));

    [NewRelic.Api.Agent.Transaction]
    private async void AdjustScore(Team team, int delta)
    {
        var key = ScoreCooldownKey(team, delta);
        if (_scoreCooldownKeys.Contains(key)) return; // ignore rapid repeat clicks
        _scoreCooldownKeys.Add(key);

        team.Score += delta;
        _scoreApplied = true;

        var verb = delta >= 0 ? "Awarded" : "Removed";
        var preposition = delta >= 0 ? "to" : "from";
        ShowScoreToast($"{verb} {Math.Abs(delta)} {preposition} {team.Name} — now {team.Score} pts");

        _ = ReenableScoreButtonAsync(key);
        await RecordTeamScoreAsync(team);
    }

    // Manual scoreboard edit: set a team's score to an absolute value (no cooldown —
    // it's a deliberate correction, not a repeatable +/- click).
    [NewRelic.Api.Agent.Transaction]
    private async void SetScore(Team team, int newScore)
    {
        team.Score = newScore;
        _scoreApplied = true;
        ShowScoreToast($"Set {team.Name} to {newScore} pts");
        await RecordTeamScoreAsync(team);
    }

    private void ShowScoreToast(string message)
    {
        _lastScoreMessage = message;
        _showScoreToast = true;
        var toastVersion = ++_scoreToastVersion;
        StateHasChanged();
        _ = HideScoreToastAfterDelayAsync(toastVersion);
    }

    // Telemetry only — must never fault the circuit. The New Relic browser helper
    // throws "newrelic is not defined" when the browser agent isn't loaded (e.g.
    // local dev); swallow it so scoring keeps working.
    private async Task RecordTeamScoreAsync(Team team)
    {
        try
        {
            await JS.InvokeAsync<string>("RecordTeamScore", team.Name, team.Score);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "RecordTeamScore JS interop failed; continuing");
        }
    }

    private async Task ReenableScoreButtonAsync(string key)
    {
        try { await Task.Delay(TimeSpan.FromSeconds(ScoreButtonCooldownSeconds)); }
        finally
        {
            await InvokeAsync(() =>
            {
                _scoreCooldownKeys.Remove(key);
                StateHasChanged();
            });
        }
    }

    private async Task HideScoreToastAfterDelayAsync(int expectedVersion)
    {
        try { await Task.Delay(TimeSpan.FromSeconds(ScoreToastSeconds)); }
        catch (TaskCanceledException) { return; }

        await InvokeAsync(() =>
        {
            // Only hide if no newer toast replaced this one in the meantime.
            if (expectedVersion != _scoreToastVersion) return;
            _showScoreToast = false;
            StateHasChanged();
        });
    }

    private void BuzzIn(Team team)
    {
        if (_buzzerLocked) return;
        _buzzedTeam = team;
        _buzzerLocked = true;
        StopTimer();
        ShowBuzzHighlight(team.Name);
    }

    private void ResetBuzzState()
    {
        _buzzerLocked = false;
        _buzzedTeam = null;
        _remoteBuzzedName = null;
        _scoreApplied = false;
        ClearBuzzHighlight();
    }

    private void ShowBuzzHighlight(string teamName)
    {
        if (string.IsNullOrWhiteSpace(teamName)) return;
        _buzzHighlightName = teamName;
        _showBuzzHighlight = true;
        var currentVersion = ++_buzzHighlightVersion;
        _ = HideBuzzHighlightAfterDelayAsync(currentVersion);
    }

    private async Task HideBuzzHighlightAfterDelayAsync(int expectedVersion)
    {
        try { await Task.Delay(TimeSpan.FromSeconds(5)); }
        catch (TaskCanceledException) { return; }

        if (expectedVersion != _buzzHighlightVersion) return;

        await InvokeAsync(() =>
        {
            if (expectedVersion != _buzzHighlightVersion) return;
            _showBuzzHighlight = false;
            StateHasChanged();
        });
    }

    private void ClearBuzzHighlight()
    {
        _buzzHighlightVersion++;
        _showBuzzHighlight = false;
        _buzzHighlightName = null;
    }

    private void ResetBuzz()
    {
        ResetBuzzState();
        // Re-open the buzz window (sets _questionStartedUnixMs; restarts legacy polling if applicable).
        // On the SignalR path _questionStartedUnixMs is updated so late buzzes from before the
        // reset are ignored by the OnBuzzNotification filter.
        OpenBuzzWindow();
        // _lastHandledBuzzUnixMs is only used by the legacy polling path.
        if (_useLegacyBuzzPolling)
        {
            _lastHandledBuzzUnixMs = _questionStartedUnixMs;
        }
        StartTimer();
    }

    private void StartBuzzPolling()
    {
        StopBuzzPolling();
        if (!_enableBuzzer || !BuzzService.IsConfigured) return;
        // _questionStartedUnixMs is set by OpenBuzzWindow before StartBuzzPolling is called.
        _lastHandledBuzzUnixMs = _questionStartedUnixMs;
        _buzzPollingCancellation = new CancellationTokenSource();
        _ = PollRemoteBuzzAsync(_buzzPollingCancellation.Token);
    }

    private void StopBuzzPolling()
    {
        if (_buzzPollingCancellation is null) return;
        _buzzPollingCancellation.Cancel();
        _buzzPollingCancellation.Dispose();
        _buzzPollingCancellation = null;
    }

    private async Task PollRemoteBuzzAsync(CancellationToken cancellationToken)
    {
        using var pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await pollTimer.WaitForNextTickAsync(cancellationToken))
            {
                if (_phase != GamePhase.Question || _buzzerLocked) continue;

                // Ask New Relic for the FIRST buzz since this question opened (server-side
                // earliest() SINCE the question-start epoch), so the first team to buzz wins.
                var buzz = await BuzzService.GetFirstBuzzSinceAsync(_questionStartedUnixMs, cancellationToken);
                if (buzz is null) continue;

                if (buzz.TimestampUnixMs <= _lastHandledBuzzUnixMs || buzz.TimestampUnixMs < _questionStartedUnixMs)
                    continue;

                _lastHandledBuzzUnixMs = buzz.TimestampUnixMs;
                Logger.LogInformation("Handling remote buzz: Name={0}, Timestamp={1}", buzz.Name, buzz.TimestampUnixMs);
                await InvokeAsync(() => HandleRemoteBuzz(buzz.Name));
            }
        }
        catch (OperationCanceledException) { }
    }

    private void HandleRemoteBuzz(string participantName)
    {
        if (_buzzerLocked || string.IsNullOrWhiteSpace(participantName)) return;

        var normalizedName = participantName.Trim();
        var matchingTeam = _teams.FirstOrDefault(team =>
            string.Equals(team.Name, normalizedName, StringComparison.OrdinalIgnoreCase));

        if (matchingTeam is not null)
        {
            _remoteBuzzedName = matchingTeam.Name;
            BuzzIn(matchingTeam);
            StateHasChanged();
            return;
        }

        Logger.LogInformation("Ignoring remote buzz from unknown team: {0}", normalizedName);
    }

    /// <summary>
    /// Subscription handler for the SignalR push path (IBuzzNotifier).
    /// Called from a thread-pool thread; marshals onto the Blazor circuit via InvokeAsync.
    /// </summary>
    private void OnBuzzNotification(BuzzNotification notification)
    {
        // Filter: only act during an open, unlocked question, and only for buzzes
        // timestamped at or after the question opened.
        if (_phase != GamePhase.Question || _buzzerLocked || notification.BuzzedAtUtcMs < _questionStartedUnixMs)
            return;

        // _lastHandledBuzzUnixMs is not used on the SignalR path — the collection window plus
        // _buzzerLocked decide the winner. Marshal onto the circuit thread, where all buzz-window
        // state is mutated single-threaded.
        _ = InvokeAsync(() => CollectBuzzAsync(notification.Name, notification.BuzzedAtUtcMs));
    }

    /// <summary>
    /// SignalR push path: gather buzzes for a short window, then award the team whose buzz has the
    /// lowest server-stamped timestamp (the team that actually buzzed first, regardless of the order
    /// the buzzes arrived over the network). Runs on the Blazor circuit thread.
    /// </summary>
    private async Task CollectBuzzAsync(string participantName, long buzzedAtUtcMs)
    {
        if (_buzzerLocked) return;

        var normalizedName = participantName.Trim();
        var matchingTeam = _teams.FirstOrDefault(team =>
            string.Equals(team.Name, normalizedName, StringComparison.OrdinalIgnoreCase));
        if (matchingTeam is null)
        {
            Logger.LogInformation("Ignoring remote buzz from unknown team: {0}", normalizedName);
            return;
        }

        _buzzCandidates.Add((matchingTeam, buzzedAtUtcMs));
        Logger.LogInformation("Buzz candidate collected: Team={0}, BuzzedAtUtcMs={1}", matchingTeam.Name, buzzedAtUtcMs);

        // A window is already open — this buzz simply joined it.
        if (_collectingBuzzes) return;

        _collectingBuzzes = true;
        var round = _buzzRoundId;

        await Task.Delay(BuzzWindowMs);

        // Abort if the round changed (reset / new question), the buzzer locked some other way
        // (e.g. timer expiry), or we left the Question phase while the window was open.
        if (round != _buzzRoundId || _buzzerLocked || _phase != GamePhase.Question)
        {
            return;
        }

        _collectingBuzzes = false;
        if (_buzzCandidates.Count == 0) return;

        // Lowest timestamp wins. OrderBy is stable, so ties fall back to arrival order.
        var winner = _buzzCandidates.OrderBy(c => c.Ts).First();
        _buzzCandidates.Clear();

        Logger.LogInformation("Buzz window closed: winner Team={0}, BuzzedAtUtcMs={1}", winner.Team.Name, winner.Ts);
        _remoteBuzzedName = winner.Team.Name;
        BuzzIn(winner.Team);
        StateHasChanged();
    }

    /// <summary>
    /// Opens the buzz window for the current question.
    /// Always sets _questionStartedUnixMs regardless of transport.
    /// Routes to legacy polling or notifier subscription based on _useLegacyBuzzPolling.
    /// </summary>
    private void OpenBuzzWindow()
    {
        _questionStartedUnixMs = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        ResetBuzzCollection();

        if (_useLegacyBuzzPolling)
        {
            StartBuzzPolling();
        }
        // On the SignalR path _questionStartedUnixMs is already set above and the
        // OnBuzzNotification subscription is already live — nothing more to do.
    }

    /// <summary>
    /// Closes the buzz window for the current question.
    /// Routes to legacy polling teardown or is a no-op on the SignalR path.
    /// </summary>
    private void CloseBuzzWindow()
    {
        ResetBuzzCollection();

        if (_useLegacyBuzzPolling)
        {
            StopBuzzPolling();
        }
        // On the SignalR path the subscription stays live (it filters by phase + lock),
        // so there is nothing to tear down here.
    }

    /// <summary>
    /// Invalidates any in-flight buzz collection window and clears gathered candidates.
    /// Bumping the round id makes a pending CollectBuzzAsync continuation bail instead of
    /// awarding a stale winner after a reset / new question.
    /// </summary>
    private void ResetBuzzCollection()
    {
        _buzzRoundId++;
        _collectingBuzzes = false;
        _buzzCandidates.Clear();
    }

    private void StartTimer()
    {
        StopTimer();
        if (!_enableTimer || _phase != GamePhase.Question) return;

        _timeRemaining = Math.Max(1, _questionSeconds);
        var timerIntervalMs = _activeChaos.Contains("timerdrift") ? 500 : 1000;
        if (_activeChaos.Contains("timerdrift")) Logger.LogInformation("[CHAOS] timerdrift: timer running at 2x speed");
        _timer = new System.Timers.Timer(timerIntervalMs);
        _timer.Elapsed += async (_, _) =>
        {
            if (_phase != GamePhase.Question) return;
            _timeRemaining--;
            if (_timeRemaining <= 0)
            {
                _timeRemaining = 0;
                StopTimer();
                _phase = GamePhase.Answer;
                _buzzerLocked = true;
            }
            await InvokeAsync(StateHasChanged);
        };
        _timer.AutoReset = true;
        _timer.Start();
    }

    private void StopTimer()
    {
        if (_timer is null) return;
        _timer.Stop();
        _timer.Dispose();
        _timer = null;
    }

    private void AssignDoubleDowns()
    {
        var allQuestions = _categories.SelectMany(c => c.Questions).ToList();
        if (allQuestions.Count == 0) return;
        var doubleDownCount = Math.Max(1, _categories.Count / 3);
        foreach (var question in allQuestions.OrderBy(_ => Random.Shared.Next()).Take(doubleDownCount))
        {
            question.IsDoubleDown = true;
        }
    }

    public void Dispose()
    {
        if (!_useLegacyBuzzPolling)
        {
            BuzzNotifier.BuzzReceived -= OnBuzzNotification;
        }
        StopBuzzPolling();
        StopTimer();
        _chaosErrorVersion++;
        _chaosCancellation?.Cancel();
        _chaosCancellation?.Dispose();
        _chaosCancellation = null;
    }
}
